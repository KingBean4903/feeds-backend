-- KEY[1] = following:userA
-- KEY[2] = followers:userB
-- KEY[3] = following_count:userA
-- KEY[4] = followers_count:userB
------------------
-- ARG[1] = userA
-- ARG[2] = userB
--


local followingKey = "following:" .. ARGV[1] 
local followersKey = "followers:" .. ARGV[2]

local followingCountKey = "following_count:" .. ARGV[1] 
local followersCountKey = "followers_count:" .. ARGV[2]
local celebThreshold = tonumber(ARGV[3]) or 50000

local added = redis.call("SADD", followingKey, followersKey)

if added == 0 then
  return 0
end

  -- Check count of user
local tier1 = tonumber(redis.call("GET", followersCountKey)) or 0 -- userA flws count

if tier1 < celebThreshold then
  redis.call("SADD", followersKey, ARGV[1]) -- add follower to set followers:userB
end

local newCount = tier1 + 1

if newCount == celebThreshold then
    redis.call("SET", "user:tier:" .. ARGV[2], "CELEBRITY")
else 
  redis.call("SET", "user:tier:" .. ARGV[2], "REGULAR")
end

redis.call("INCR", followingCountKey)
redis.call("INCR", followersCountKey)




